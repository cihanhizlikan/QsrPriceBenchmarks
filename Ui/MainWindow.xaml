<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:QsrPriceBenchmarks.Ui.Converters"
        xmlns:local="clr-namespace:QsrPriceBenchmarks.Ui"
        x:Class="QsrPriceBenchmarks.Ui.MainWindow"
        Title="QSR Price Benchmarks"
        Width="1200" Height="820" MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolVis"/>
    <cv:BoolToVisibilityConverter x:Key="InvVis"  WhenTrue="Collapsed" WhenFalse="Visible"/>
    <cv:InverseBoolConverter      x:Key="InvBool"/>
    <cv:NullToVisibilityConverter x:Key="NullVis"/>
    <cv:NullToVisibilityConverter x:Key="InvNullVis" WhenNull="Visible" WhenNotNull="Collapsed"/>

    <!-- App logo: three ascending "benchmark" bars in light + dim cyan -->
    <DrawingImage x:Key="AppLogo">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="{StaticResource BrushDimCyan}">
            <GeometryDrawing.Geometry>
              <RectangleGeometry Rect="3,13,5,8" RadiusX="1.5" RadiusY="1.5"/>
            </GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="{StaticResource BrushLightCyan}">
            <GeometryDrawing.Geometry>
              <RectangleGeometry Rect="10,8,5,13" RadiusX="1.5" RadiusY="1.5"/>
            </GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="{StaticResource BrushDimCyan}">
            <GeometryDrawing.Geometry>
              <RectangleGeometry Rect="17,3,5,18" RadiusX="1.5" RadiusY="1.5"/>
            </GeometryDrawing.Geometry>
          </GeometryDrawing>
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="#111111"
            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0 0 0 1">
      <DockPanel Margin="16 0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Grid Width="22" Height="22" Margin="0 0 9 0" VerticalAlignment="Center"
                UseLayoutRounding="True" SnapsToDevicePixels="True">
            <!-- Static logo when idle -->
            <Image Source="{StaticResource AppLogo}" Width="22" Height="22"
                   Visibility="{Binding IsRunning, Converter={StaticResource InvVis}}"/>
            <!-- Animated cyan equalizer bars while a step is running. Shown by
                 toggling visibility against the logo (no opaque cover) so there's
                 no seam, and sized to the full 22×22 logo footprint. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
              <StackPanel.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                      <DoubleAnimation Storyboard.TargetName="Bar1"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                       From="0.35" To="1.0" Duration="0:0:0.5"/>
                      <DoubleAnimation Storyboard.TargetName="Bar2" BeginTime="0:0:0.16"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                       From="0.9" To="0.3" Duration="0:0:0.5"/>
                      <DoubleAnimation Storyboard.TargetName="Bar3" BeginTime="0:0:0.32"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                       From="0.5" To="1.0" Duration="0:0:0.5"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </StackPanel.Triggers>
              <Rectangle x:Name="Bar1" Width="4" Height="22" Margin="1 0"
                         Fill="{StaticResource BrushLightCyan}" RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform><ScaleTransform ScaleY="0.4"/></Rectangle.RenderTransform>
              </Rectangle>
              <Rectangle x:Name="Bar2" Width="4" Height="22" Margin="1 0"
                         Fill="{StaticResource BrushDimCyan}" RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform><ScaleTransform ScaleY="0.9"/></Rectangle.RenderTransform>
              </Rectangle>
              <Rectangle x:Name="Bar3" Width="4" Height="22" Margin="1 0"
                         Fill="{StaticResource BrushLightCyan}" RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform><ScaleTransform ScaleY="0.5"/></Rectangle.RenderTransform>
              </Rectangle>
            </StackPanel>
          </Grid>
          <TextBlock Text="QSR Price Benchmarks" FontSize="16" FontWeight="SemiBold"
                     Foreground="{StaticResource BrushLightCyan}" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Margin="24 0">
          <TextBlock Text="DB:" Foreground="{StaticResource BrushTextDim}"
                     VerticalAlignment="Center" Margin="0 0 6 0"/>
          <TextBox Width="320" Text="{Binding DbPath, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"
                   VerticalAlignment="Center"/>
          <Button Content="Browse" Margin="6 0 0 0" Padding="10 4" VerticalAlignment="Center"
                  Command="{Binding BrowseDbCommand}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── Main content ────────────────────────────────────────────────────── -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ── Left sidebar: chain selector (ListBox) ─────────────────────────── -->
      <Border Grid.Column="0" Background="#111111"
              BorderBrush="{StaticResource BrushBorder}" BorderThickness="0 0 1 0">
        <DockPanel Margin="10">
          <TextBlock DockPanel.Dock="Top" Text="SELECT CHAIN"
                     Foreground="{StaticResource BrushTextDim}"
                     FontSize="10" FontWeight="SemiBold" Margin="4 6 0 10"/>
          <ListBox ItemsSource="{Binding Chains}"
                   SelectedItem="{Binding SelectedChain, Mode=TwoWay}"
                   IsHitTestVisible="{Binding IsRunning, Converter={StaticResource InvBool}}"
                   Tag="{Binding IsRunning}"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding"     Value="0"/>
                <Setter Property="Margin"      Value="0 0 0 6"/>
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="Bd" Background="{StaticResource BrushBg2}"
                              BorderBrush="{StaticResource BrushBorder}"
                              BorderThickness="1" CornerRadius="6" Padding="10 8"
                              Cursor="Hand">
                        <ContentPresenter/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="Background"  Value="{StaticResource BrushBg3}"/>
                          <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushDimCyan}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="Bd" Property="Background"  Value="{StaticResource BrushAccentBg}"/>
                          <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushLightCyan}"/>
                        </Trigger>
                        <!-- While a run is in progress, the selected chain takes
                             the exact look of the disabled Run button — accent bg
                             + cyan border at 0.4 opacity — to signify it's locked.
                             Other cards are left untouched. -->
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                            <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True"/>
                          </MultiDataTrigger.Conditions>
                          <Setter TargetName="Bd" Property="Background"  Value="{StaticResource BrushAccentBg}"/>
                          <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushLightCyan}"/>
                          <Setter TargetName="Bd" Property="Opacity"     Value="0.4"/>
                        </MultiDataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <Border Width="34" Height="34" CornerRadius="5"
                          Background="{Binding BadgeBrush}" Margin="0 0 10 0">
                    <!-- Real logo when stored -->
                    <Grid>
                      <Image Source="{Binding LogoImage}"
                             Visibility="{Binding LogoImage, Converter={StaticResource NullVis}}"
                             Stretch="UniformToFill"
                             RenderOptions.BitmapScalingMode="HighQuality"/>
                      <TextBlock Text="{Binding Initials}"
                                 Visibility="{Binding LogoImage, Converter={StaticResource InvNullVis}}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 FontWeight="Bold" FontSize="12" Foreground="{Binding BadgeForeground}"/>
                    </Grid>
                  </Border>
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                             FontSize="12" TextWrapping="Wrap" MaxWidth="128"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- ── Right: TabControl ──────────────────────────────────────────────── -->
      <TabControl Grid.Column="1" SelectionChanged="MainTabs_SelectionChanged">

        <!-- ═══ TAB 1: Run Pipeline ══════════════════════════════════════════ -->
        <TabItem Header="  Run Pipeline  ">
          <Grid Margin="12 10 12 12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Step options panel -->
            <Border Grid.Row="0" Background="{StaticResource BrushBg2}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="16 12" Margin="0 0 0 12">
              <StackPanel>
                <TextBlock Text="PIPELINE OPTIONS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextDim}" Margin="0 0 0 12"/>

                <!-- Full run notice -->
                <TextBlock Visibility="{Binding IsSelective, Converter={StaticResource InvVis}}"
                           Foreground="{StaticResource BrushDimCyan}" FontStyle="Italic" Margin="0 0 0 12">
                  No step flags selected —
                  <Run FontWeight="SemiBold" Foreground="{StaticResource BrushLightCyan}">Full Run</Run>
                  (Steps 1 → 2 → 3)
                </TextBlock>

                <WrapPanel>
                  <CheckBox Content="Force Crawl (Step 1)" Margin="0 0 16 8"
                            IsChecked="{Binding ForceCrawl}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
                  <CheckBox Content="Geocode (Step 3)" Margin="0 0 16 8"
                            IsChecked="{Binding Geocode}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
                  <CheckBox Content="↳ Rematch all" Margin="0 0 16 8"
                            IsChecked="{Binding GeocodeRematch}"
                            IsEnabled="{Binding IsRematchEnabled}"
                            ToolTip="Reset every match first, then rematch from scratch. Requires Geocode."/>
                </WrapPanel>

                <!-- Tabs to scrape — shown only for a full run; all ticked by default -->
                <StackPanel Margin="0 4 0 0"
                            Visibility="{Binding ShowTabSelection, Converter={StaticResource BoolVis}}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}">
                  <TextBlock Text="TABS TO SCRAPE" FontSize="10" FontWeight="SemiBold"
                             Foreground="{StaticResource BrushTextDim}" Margin="0 0 0 8"/>
                  <ItemsControl ItemsSource="{Binding ScrapeTabs}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding Name}" Margin="0 0 16 8"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 12">
              <Button Content="▶  Run" Style="{StaticResource ButtonRun}"
                      Command="{Binding RunCommand}" Margin="0 0 8 0"/>
              <Button Content="■  Cancel" Padding="14 8"
                      Command="{Binding CancelCommand}" Margin="0 0 8 0"
                      Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
            </StackPanel>

            <!-- Log output -->
            <Border Grid.Row="2" Background="{StaticResource BrushBg2}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer x:Name="LogScroller" Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              ScrollChanged="LogScroller_ScrollChanged"
                              Padding="12 8">
                  <ItemsControl ItemsSource="{Binding LogLines}" x:Name="LogItemsControl">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock local:LogTextBehavior.Line="{Binding}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource BrushText}" TextWrapping="Wrap"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <!-- Step-3 geocoding progress, in the output panel with the log -->
                <Border Grid.Row="1" Padding="12 8"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="0 1 0 0"
                        Visibility="{Binding ProgressVisible, Converter={StaticResource BoolVis}}">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="240" Minimum="0"
                                 Maximum="{Binding ProgressTotal, Mode=OneWay}" Value="{Binding ProgressDone, Mode=OneWay}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProgressText}" Margin="10 0 0 0" VerticalAlignment="Center"
                               FontFamily="Consolas" FontSize="12" Foreground="{StaticResource BrushDimCyan}"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <!-- Footer -->
            <TextBlock Grid.Row="3" Margin="0 8 0 0" FontSize="11"
                       Foreground="{StaticResource BrushTextDim}">
              <Run Foreground="{StaticResource BrushLightCyan}" Text="{Binding LogLines.Count, Mode=OneWay}"/>
              <Run Text=" log lines"/>
            </TextBlock>
          </Grid>
        </TabItem>

        <!-- ═══ TAB 2: Locations (vector map of Türkiye) ═════════════════════ -->
        <TabItem x:Name="LocationsTab" Header="  Locations  ">
          <Grid Margin="12 10 12 12">
            <Grid.Resources>
              <!-- District outline: dimmed cyan, brighter where the chain has
                   locations, brightest on hover. -->
              <Style x:Key="DistrictPath" TargetType="Path">
                <Setter Property="Fill" Value="#1A00B3B3"/>
                <Setter Property="Stroke" Value="#8000B3B3"/>
                <Setter Property="StrokeThickness" Value="0.5"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasLocations}" Value="True">
                    <Setter Property="Fill" Value="#3D00FFFF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                  </DataTrigger>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#6000FFFF"/>
                    <Setter Property="Stroke" Value="{StaticResource BrushLightCyan}"/>
                    <Setter Property="StrokeThickness" Value="1"/>
                  </Trigger>
                </Style.Triggers>
              </Style>

              <!-- Dark-gray, rounded, light-cyan outlined tooltip. -->
              <Style x:Key="MapToolTip" TargetType="ToolTip">
                <Setter Property="Foreground" Value="{StaticResource BrushLightCyan}"/>
                <Setter Property="Background" Value="#202020"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                      <Border Background="{TemplateBinding Background}" CornerRadius="6"
                              BorderBrush="{StaticResource BrushLightCyan}" BorderThickness="1"
                              Padding="10 8">
                        <ContentPresenter/>
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 8">
              <TextBlock Text="Locations map —" VerticalAlignment="Center"
                         Foreground="{StaticResource BrushTextDim}"/>
              <TextBlock VerticalAlignment="Center" Margin="6 0 0 0"
                         Foreground="{StaticResource BrushLightCyan}" FontWeight="SemiBold"
                         Text="{Binding SelectedChain.Name, TargetNullValue='select a chain'}"/>
              <Border Margin="10 0 0 0" Padding="8 2" CornerRadius="9"
                      Background="{StaticResource BrushBg2}"
                      BorderBrush="{StaticResource BrushDimCyan}" BorderThickness="1"
                      VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource BrushLightCyan}"
                           Text="{Binding LocationTotal, StringFormat='{}{0} locations'}"/>
              </Border>
              <TextBlock VerticalAlignment="Center" Margin="12 0 0 0"
                         Foreground="{StaticResource BrushTextDim}"
                         Text="hover a province with locations to see its districts"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource BrushBg2}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="2">
              <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="-8 -18">
                <ItemsControl ItemsSource="{Binding MapCells}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <!-- SVG viewBox 0 0 1000 422; geometry coords are absolute -->
                      <Canvas Width="1000" Height="422" Background="Transparent"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>

                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Canvas>
                        <!-- District outline (absolute geometry, no offset) -->
                        <Path Data="{Binding Shape}" Style="{StaticResource DistrictPath}"
                              IsHitTestVisible="{Binding HasLocations}"
                              ToolTipService.IsEnabled="{Binding HasLocations}"
                              ToolTipService.InitialShowDelay="120"
                              ToolTipService.BetweenShowDelay="0">
                          <Path.ToolTip>
                            <ToolTip Style="{StaticResource MapToolTip}">
                              <StackPanel MinWidth="150">
                                <TextBlock Text="{Binding ProvinceName}" FontWeight="SemiBold"
                                           FontSize="14" Margin="0 0 0 5"
                                           Foreground="{StaticResource BrushLightCyan}"/>
                                <ItemsControl ItemsSource="{Binding DistrictColumns}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <ItemsControl ItemsSource="{Binding}" Margin="0 0 16 0">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate>
                                            <TextBlock Text="{Binding}" Margin="0 1"
                                                       Foreground="{StaticResource BrushLightCyan}"/>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ToolTip>
                          </Path.ToolTip>
                        </Path>

                        <!-- Emanating marker at the district centroid -->
                        <Grid Canvas.Left="{Binding DotLeft}" Canvas.Top="{Binding DotTop}"
                              Width="30" Height="30" IsHitTestVisible="False"
                              Visibility="{Binding HasLocations, Converter={StaticResource BoolVis}}">
                          <Grid.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                              <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                  <DoubleAnimation Storyboard.TargetName="Ring"
                                                   Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                   From="0.5" To="2.6" Duration="0:0:2"/>
                                  <DoubleAnimation Storyboard.TargetName="Ring"
                                                   Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                   From="0.5" To="2.6" Duration="0:0:2"/>
                                  <DoubleAnimation Storyboard.TargetName="Ring"
                                                   Storyboard.TargetProperty="Opacity"
                                                   From="0.7" To="0" Duration="0:0:2"/>
                                </Storyboard>
                              </BeginStoryboard>
                            </EventTrigger>
                          </Grid.Triggers>
                          <Ellipse x:Name="Ring" Width="14" Height="14" Opacity="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Stroke="{StaticResource BrushLightCyan}" StrokeThickness="1.5"
                                   RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                              <ScaleTransform/>
                            </Ellipse.RenderTransform>
                          </Ellipse>
                          <Ellipse Width="8" Height="8" Fill="{StaticResource BrushLightCyan}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                      </Canvas>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Viewbox>
            </Border>
          </Grid>
        </TabItem>

        <!-- ═══ TAB 3: Scrape Runs ═══════════════════════════════════════════ -->
        <TabItem x:Name="ScrapeRunsTab" Header="  Scrape Runs  ">
          <Grid Margin="12 10 12 12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 12">
              <Button Content="📁  Open Folder" Padding="14 8"
                      Command="{Binding OpenFolderCommand}" Margin="0 0 12 0"/>
              <Border Width="1" Height="22" Background="{StaticResource BrushBorder}" Margin="0 0 12 0"/>
              <TextBlock Text="Delete all before run ID:" VerticalAlignment="Center"
                         Foreground="{StaticResource BrushTextDim}" Margin="0 0 6 0"/>
              <TextBox Width="70"
                       Text="{Binding DeleteBeforeId, UpdateSourceTrigger=PropertyChanged}"
                       IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
              <Button Content="Delete Before" Style="{StaticResource ButtonDanger}"
                      Command="{Binding DeleteBeforeIdCommand}"
                      Margin="6 0 0 0" Padding="14 8"/>
            </StackPanel>

            <!-- Runs grid -->
            <DataGrid Grid.Row="1" ItemsSource="{Binding Runs}" IsReadOnly="True"
                      SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}" Width="60"
                                    ElementStyle="{StaticResource GridCellText}"/>
                <DataGridTextColumn Header="Chain"
                                    Binding="{Binding QsrName}" Width="150"
                                    ElementStyle="{StaticResource GridCellText}"/>
                <DataGridTextColumn Header="Started"
                                    Binding="{Binding StartedAt}" Width="*"
                                    ElementStyle="{StaticResource GridCellText}"/>
                <DataGridTextColumn Header="Finished"
                                    Binding="{Binding FinishedAt}" Width="*"
                                    ElementStyle="{StaticResource GridCellText}"/>
                <DataGridTextColumn Header="Snapshots"
                                    Binding="{Binding SnapshotCount, StringFormat=N0}" Width="100"
                                    ElementStyle="{StaticResource GridCellText}"/>
                <DataGridTemplateColumn Header="Actions" Width="200">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                  Margin="6 0 0 0">
                        <Button Content="Export" Style="{StaticResource ButtonRun}"
                                Padding="10 4" Margin="0 2 6 2" MinWidth="74"
                                Visibility="{Binding IsFinished, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.ExportRunCommand,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding DataContext.IsExporting,
                                  RelativeSource={RelativeSource AncestorType=DataGrid},
                                  Converter={StaticResource InvBool}}"/>
                        <Button Content="Resume" Style="{StaticResource ButtonBase}"
                                Padding="10 4" Margin="0 2 6 2" MinWidth="74"
                                Visibility="{Binding IsErrored, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.ResumeRunCommand,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding DataContext.IsBusy,
                                  RelativeSource={RelativeSource AncestorType=DataGrid},
                                  Converter={StaticResource InvBool}}"/>
                        <Button Content="Delete" Style="{StaticResource ButtonDanger}"
                                Padding="10 4" Margin="0 2" MinWidth="74"
                                Visibility="{Binding IsFinished, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.DeleteRunCommand,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding DataContext.IsExporting,
                                  RelativeSource={RelativeSource AncestorType=DataGrid},
                                  Converter={StaticResource InvBool}}"/>
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <!-- Export progress (same style as the Step-3 geocoding bar) with a
                 Cancel button for very long exports. -->
            <Border Grid.Row="2" Padding="12 8" Margin="0 12 0 0"
                    Background="{StaticResource BrushBg2}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6"
                    Visibility="{Binding ExportProgressVisible, Converter={StaticResource BoolVis}}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressBar Width="240" Minimum="0"
                             Maximum="{Binding ExportTotal, Mode=OneWay}" Value="{Binding ExportDone, Mode=OneWay}"
                             VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ExportText}" Margin="10 0 0 0" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12" Foreground="{StaticResource BrushDimCyan}"/>
                <Button Content="Cancel" Style="{StaticResource ButtonBase}"
                        Margin="14 0 0 0" Padding="14 6" VerticalAlignment="Center"
                        Command="{Binding CancelExportCommand}"/>
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</Window>
